{
  "name": "personal-budgets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first personal & business budget tracker. Import CSV/Excel statements, view KPIs and transactions.",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx server/index.ts"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
